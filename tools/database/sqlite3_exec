#!/usr/bin/env python3

"""
sqlite3_exec: Execute query in sqlite3 with proper charater escape handling
Usage: sqlite3_exec <database_file> <query_text> <arg1> <arg2> ...
    <query_holder> uses `?` as argument holder, example: 'INSERT OR IGNORE INTO processed_emails (message_id, subject, sender, received_at) VALUES (?, ?, ?, ?)'
    the number of remaining arguments should be equal to `?` in query_holder
"""

import sqlite3
import sys
import os

def main():
    # 1. Basic Argument Validation
    if len(sys.argv) < 3:
        print(__doc__)
        sys.exit(1)

    db_path = sys.argv[1]
    query = sys.argv[2]
    # The rest of the arguments are the data points
    params = sys.argv[3:]

    # 2. Count Check (Helpful for debugging the Agent's logic)
    placeholder_count = query.count('?')
    if placeholder_count != len(params):
        print(f"Error: Query expected {placeholder_count} arguments, but got {len(params)}.")
        sys.exit(1)

    # 3. Database Execution
    conn = None
    try:
        # Ensure the directory exists so we don't get a 'ReadOnly' error
        os.makedirs(os.path.dirname(os.path.abspath(db_path)), exist_ok=True)
        
        conn = sqlite3.connect(db_path)
        cur = conn.cursor()

        # The '?' binding handles all escaping automatically.
        # It doesn't matter if the string has ' or " or * or even newlines.
        cur.execute(query, params)
        conn.commit()
        
        # If it was a SELECT query, we might want to see the output
        rows = cur.fetchall()
        for row in rows:
            print(row)

    except sqlite3.Error as e:
        print(f"SQLite Error: {e}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Unexpected Error: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        if conn:
            conn.close()

if __name__ == "__main__":
    main()
