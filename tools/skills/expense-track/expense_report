#!/usr/bin/env bash
# expense_report — Generate daily or monthly expense report
# Auto-detects mode: monthly on 1st of month, daily otherwise
# Always prints to stdout

set -euo pipefail

MYSQL_OPTS="-h$MYSQL_HOST -P$MYSQL_PORT -u$MYSQL_USER --default-character-set=utf8mb4 --skip-column-names --batch"

q() { MYSQL_PWD="$MYSQL_PASSWORD" mysql $MYSQL_OPTS expense -e "$1"; }

card_emoji() {
  case "$1" in
    Lexus*)   echo "🔵" ;;
    Amazon*)  echo "🟠" ;;
    PayPay*)  echo "🟢" ;;
    Cash*)    echo "🟣" ;;
    *)        echo "💳" ;;
  esac
}

daily_report() {
  local yesterday
  yesterday=$(q "SELECT CURDATE() - INTERVAL 1 DAY;")

  echo "💳 Yesterday Report — ${yesterday}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  local cards
  cards=$(q "
    SELECT DISTINCT pm.name
    FROM transactions t
    JOIN payment_methods pm ON t.payment_method_id = pm.id
    WHERE t.date = CURDATE() - INTERVAL 1 DAY
    ORDER BY pm.id;
  ")

  if [ -z "$cards" ]; then
    echo "No expenses recorded yesterday. 🎉"
  else
    while IFS= read -r card; do
      local emoji
      emoji=$(card_emoji "$card")
      echo "${emoji} ${card}"

      while IFS=$'\t' read -r store amount category; do
        echo "  • ${store} — ${amount} (${category})"
      done < <(q "
        SELECT t.store, CONCAT('¥', FORMAT(t.amount, 0)), t.category
        FROM transactions t
        JOIN payment_methods pm ON t.payment_method_id = pm.id
        WHERE t.date = CURDATE() - INTERVAL 1 DAY
          AND pm.name = '${card}'
        ORDER BY t.amount DESC;
      ")

      local subtotal
      subtotal=$(q "
        SELECT CONCAT('¥', FORMAT(COALESCE(SUM(t.amount), 0), 0))
        FROM transactions t
        JOIN payment_methods pm ON t.payment_method_id = pm.id
        WHERE t.date = CURDATE() - INTERVAL 1 DAY
          AND pm.name = '${card}';
      ")
      echo "  Subtotal: ${subtotal}"
      echo
    done <<< "$cards"
  fi

  local yesterday_total
  yesterday_total=$(q "
    SELECT CONCAT('¥', FORMAT(COALESCE(SUM(amount), 0), 0))
    FROM transactions
    WHERE date = CURDATE() - INTERVAL 1 DAY;
  ")
  echo
  echo "💰 Yesterday Total: ${yesterday_total}"
  echo

  local month_name
  month_name=$(date +"%B")

  local month_grand
  month_grand=$(q "
    SELECT CONCAT('¥', FORMAT(COALESCE(SUM(amount), 0), 0))
    FROM transactions
    WHERE date >= DATE_FORMAT(CURDATE(), '%Y-%m-01');
  ")
  echo "📊 Month-to-Date (${month_name}): <http://dashboard.goshan.info/dashboard/1-transactions-month-to-date|${month_grand}>"
}

monthly_report() {
  local last_month_label
  last_month_label=$(q "SELECT DATE_FORMAT(CURDATE() - INTERVAL 1 MONTH, '%Y-%m');")
  local month_name
  month_name=$(date -j -f "%Y-%m" "$last_month_label" "+%B %Y" 2>/dev/null \
    || date -d "${last_month_label}-01" "+%B %Y" 2>/dev/null \
    || echo "$last_month_label")

  echo "📊 Last Month Report — ${month_name}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo

  while IFS=$'\t' read -r card total; do
    local emoji
    emoji=$(card_emoji "$card")
    echo "  ${emoji} ${card}: ${total}"
  done < <(q "
    SELECT pm.name, CONCAT('¥', FORMAT(COALESCE(SUM(t.amount), 0), 0))
    FROM transactions t
    JOIN payment_methods pm ON t.payment_method_id = pm.id
    WHERE t.date >= DATE_FORMAT(CURDATE() - INTERVAL 1 MONTH, '%Y-%m-01')
      AND t.date < DATE_FORMAT(CURDATE(), '%Y-%m-01')
    GROUP BY t.payment_method_id, pm.name
    ORDER BY SUM(t.amount) DESC;
  ")

  local grand_total
  grand_total=$(q "
    SELECT CONCAT('¥', FORMAT(COALESCE(SUM(amount), 0), 0))
    FROM transactions
    WHERE date >= DATE_FORMAT(CURDATE() - INTERVAL 1 MONTH, '%Y-%m-01')
      AND date < DATE_FORMAT(CURDATE(), '%Y-%m-01');
  ")


  echo
  echo "💰 Total: <http://dashboard.goshan.info/dashboard/2-transactions-last-month|${grand_total}>"
}

# Auto-detect mode: monthly on 1st of month, daily otherwise
day_of_month=$(date +%-d)
if [[ "$day_of_month" == "1" ]]; then
  monthly_report
else
  daily_report
fi
