#!/usr/bin/env python3
"""
expense_report — Generate daily or monthly expense report as JSON.
Auto-detects mode: monthly on 1st of month, daily otherwise.
"""

import json
import os
import mysql.connector
from datetime import date, timedelta

DASHBOARD_DAILY_URL   = "http://dashboard.goshan.info/dashboard/1-transactions-month-to-date"
DASHBOARD_MONTHLY_URL = "http://dashboard.goshan.info/dashboard/2-transactions-last-month"


def get_conn():
    return mysql.connector.connect(
        host=os.environ["MYSQL_HOST"],
        port=int(os.environ.get("MYSQL_PORT", 3306)),
        user=os.environ["MYSQL_USER"],
        password=os.environ["MYSQL_PASSWORD"],
        database="expense",
        charset="utf8mb4",
    )


def q(cur, sql, params=None):
    cur.execute(sql, params)
    return cur.fetchall()


def daily_report(cur, today):
    yesterday = today - timedelta(days=1)
    this_month_start = today.replace(day=1)

    card_rows = q(cur, """
        SELECT DISTINCT pm.name
        FROM transactions t
        JOIN payment_methods pm ON t.payment_method_id = pm.id
        WHERE t.date = %s
        ORDER BY pm.id
    """, (yesterday,))

    cards = []
    for (card,) in card_rows:
        txn_rows = q(cur, """
            SELECT t.store, CONCAT('¥', FORMAT(t.amount, 0)), t.category
            FROM transactions t
            JOIN payment_methods pm ON t.payment_method_id = pm.id
            WHERE t.date = %s AND pm.name = %s
            ORDER BY t.amount DESC
        """, (yesterday, card))
        transactions = [{"store": s, "amount": a, "category": c} for s, a, c in txn_rows]

        subtotal = q(cur, """
            SELECT CONCAT('¥', FORMAT(COALESCE(SUM(t.amount), 0), 0))
            FROM transactions t
            JOIN payment_methods pm ON t.payment_method_id = pm.id
            WHERE t.date = %s AND pm.name = %s
        """, (yesterday, card))[0][0]

        cards.append({"name": card, "transactions": transactions, "subtotal": subtotal})

    yesterday_total = q(cur, """
        SELECT CONCAT('¥', FORMAT(COALESCE(SUM(amount), 0), 0))
        FROM transactions WHERE date = %s
    """, (yesterday,))[0][0]

    month_to_date = q(cur, """
        SELECT CONCAT('¥', FORMAT(COALESCE(SUM(amount), 0), 0))
        FROM transactions WHERE date >= %s
    """, (this_month_start,))[0][0]

    return {
        "mode":          "daily",
        "date":          str(yesterday),
        "cards":         cards,
        "total":         yesterday_total,
        "month":         today.strftime("%Y-%m"),
        "accumulated_total": month_to_date,
        "dashboard_url": DASHBOARD_DAILY_URL,
    }


def monthly_report(cur, today):
    last_month_start = (today.replace(day=1) - timedelta(days=1)).replace(day=1)
    this_month_start = today.replace(day=1)
    month_name = last_month_start.strftime("%Y-%m")

    card_rows = q(cur, """
        SELECT pm.name, CONCAT('¥', FORMAT(COALESCE(SUM(t.amount), 0), 0))
        FROM transactions t
        JOIN payment_methods pm ON t.payment_method_id = pm.id
        WHERE t.date >= %s AND t.date < %s
        GROUP BY t.payment_method_id, pm.name
        ORDER BY SUM(t.amount) DESC
    """, (last_month_start, this_month_start))
    cards = [{"name": name, "total": total} for name, total in card_rows]

    grand_total = q(cur, """
        SELECT CONCAT('¥', FORMAT(COALESCE(SUM(amount), 0), 0))
        FROM transactions WHERE date >= %s AND date < %s
    """, (last_month_start, this_month_start))[0][0]

    return {
        "mode":          "monthly",
        "month":         month_name,
        "cards":         cards,
        "grand_total":   grand_total,
        "dashboard_url": DASHBOARD_MONTHLY_URL,
    }


if __name__ == "__main__":
    today = date.today()
    conn = get_conn()
    try:
        cur = conn.cursor()
        data = monthly_report(cur, today) if today.day == 1 else daily_report(cur, today)
    finally:
        conn.close()
    print(json.dumps(data, ensure_ascii=False))
