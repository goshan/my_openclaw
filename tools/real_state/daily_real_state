#!/usr/bin/env bash
# daily_real_state — Print today's real estate metrics as tab-separated values.
# Columns: label, avg, count, dod_pct, wow_pct, mom_pct, yoy_pct
# NULL is output as empty string for missing comparison periods.
# Always prints to stdout.

set -euo pipefail

MYSQL_OPTS="-h$MYSQL_HOST -P$MYSQL_PORT -u$MYSQL_USER --default-character-set=utf8mb4 --skip-column-names --batch"

today=$(date +%Y-%m-%d)

MYSQL_PWD="$MYSQL_PASSWORD" mysql $MYSQL_OPTS real_state -e "
  SELECT
    l.label,
    FORMAT(ROUND(t.average), 0),
    t.count,
    ROUND((t.average - d.average) / d.average * 100, 1),
    ROUND((t.average - w.average) / w.average * 100, 1),
    ROUND((t.average - m.average) / m.average * 100, 1),
    ROUND((t.average - y.average) / y.average * 100, 1)
  FROM daily_metrics t
  JOIN  locations l ON l.code = t.location_code
  LEFT JOIN daily_metrics d ON d.location_code = t.location_code AND d.date = t.date - INTERVAL 1 DAY
  LEFT JOIN daily_metrics w ON w.location_code = t.location_code AND w.date = t.date - INTERVAL 7 DAY
  LEFT JOIN daily_metrics m ON m.location_code = t.location_code AND m.date = t.date - INTERVAL 1 MONTH
  LEFT JOIN daily_metrics y ON y.location_code = t.location_code AND y.date = t.date - INTERVAL 1 YEAR
  WHERE t.date = '${today}'
  ORDER BY l.layer, l.label;
"
