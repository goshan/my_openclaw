# ── Helpers ────────────────────────────────────────────────────────────────────

def fetch_json(url, headers=None):
    req = urllib.request.Request(url, headers=headers or {})
    with urllib.request.urlopen(req, timeout=10) as resp:
        return json.loads(resp.read().decode())


def run(cmd):
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout.strip()


def divider(title):
    print(f"\n{'━' * 32}")
    print(f"  {title}")
    print('━' * 32)


def dw(s):
    """Return the display width of a string, counting CJK/emoji as 2."""
    w = 0
    for ch in s:
        eaw = unicodedata.east_asian_width(ch)
        w += 2 if eaw in ('W', 'F', 'A') else 1
    return w


def rpad(s, width):
    """Left-align s in a field of given display width."""
    return s + ' ' * max(0, width - dw(s))


def lpad(s, width):
    """Right-align s in a field of given display width."""
    return ' ' * max(0, width - dw(s)) + s


def fmt_pct(val):
    if val is None:
        return "⬜—"
    try:
        n = float(val)
    except (ValueError, TypeError):
        return str(val)
    if n > 0:
        return f"🔴+{val}%"
    elif n < 0:
        return f"🟢{val}%"
    else:
        return "⬜0%"


def card_emoji(name):
    if name.startswith("Lexus"):   return "🔵"
    if name.startswith("Amazon"):  return "🟠"
    if name.startswith("PayPay"):  return "🟢"
    if name.startswith("Cash"):    return "🟣"
    return "💳"


# ── Steps ──────────────────────────────────────────────────────────────────────

def step_weather():
    divider("🌤 天气 · 东京")
    try:
        data = fetch_json("https://wttr.in/Tokyo?format=j1&lang=zh")
        cur  = data["current_condition"][0]
        cond = cur["lang_zh"][0]["value"]
        print(f"  天气状况 : {cond}")
        print(f"  当前     : {cur['temp_C']}°C  (feels like {cur['FeelsLikeC']}°C)")
        print(f"  湿度     : {cur['humidity']}%")
        print(f"  风速     : {cur['windspeedKmph']} km/h")
        today_w = data["weather"][0]
        print(f"  气温     : {today_w['mintempC']}°C - {today_w['maxtempC']}°C")
        print("  未来3天  :")
        for day in data["weather"]:
            # The hourly array has 8 entries in 3-hour intervals. Index 4 = 12:00. Use noon condition as the whole day condition
            fc_cond = day["hourly"][4]["lang_zh"][0]["value"]
            print(f"    {day['date']}: {fc_cond}, {day['mintempC']}°C – {day['maxtempC']}°C")
    except Exception as e:
        print(f"  [Error: {e}]")


def step_currency():
    divider("💱 汇率")
    for currency in ["CNY", "USD"]:
        try:
            data = fetch_json(
                f"https://api.frankfurter.app/latest?from={currency}&to=JPY",
                headers={"User-Agent": "Mozilla/5.0"},
            )
            rate = round(data["rates"]["JPY"], 1)
            print(f"  {currency} → JPY: {rate}")
        except Exception as e:
            print(f"  {currency} → JPY: [Error: {e}]")


def step_expense():
    divider("💳 支出报告")
    try:
