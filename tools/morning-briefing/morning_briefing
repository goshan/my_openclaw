#!/usr/bin/env python3
"""
morning_briefing — Collect all data for the daily morning briefing.
Outputs a structured English report to stdout.
The calling skill translates the output to Chinese.
"""

import json
import os
import subprocess
import urllib.request
from datetime import datetime


CALENDARS = [
    ("primary", "Personal"),
    ("sju3uu229khkrjin1k43e78dmk@group.calendar.google.com",           "もも家"),
    ("issh.ac.jp_kdna6o2b4h1gpd0pj9e30ih57s@group.calendar.google.com", "School"),
]


# ── Helpers ────────────────────────────────────────────────────────────────────

def fetch_json(url, headers=None):
    req = urllib.request.Request(url, headers=headers or {})
    with urllib.request.urlopen(req, timeout=10) as resp:
        return json.loads(resp.read().decode())


def run(cmd):
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout.strip()


def divider(title):
    print(f"\n{'━' * 32}")
    print(f"  {title}")
    print('━' * 32)


# ── Steps ──────────────────────────────────────────────────────────────────────

def step_weather():
    divider("🌤 Weather · Tokyo")
    try:
        data = fetch_json("https://wttr.in/Tokyo?format=j1")
        cur  = data["current_condition"][0]
        cond = cur["weatherDesc"][0]["value"]
        print(f"  Condition : {cond}")
        print(f"  Now       : {cur['temp_C']}°C  (feels like {cur['FeelsLikeC']}°C)")
        print(f"  Humidity  : {cur['humidity']}%")
        print(f"  Wind      : {cur['windspeedKmph']} km/h")
        today_w = data["weather"][0]
        print(f"  High / Low: {today_w['maxtempC']}°C / {today_w['mintempC']}°C")
        print("  3-day forecast:")
        for day in data["weather"]:
            fc_cond = day["hourly"][4]["weatherDesc"][0]["value"]  # noon condition
            print(f"    {day['date']}: {fc_cond}, {day['mintempC']}°C – {day['maxtempC']}°C")
    except Exception as e:
        print(f"  [Error: {e}]")


def step_currency():
    divider("💱 Currency Rates")
    for currency in ["CNY", "USD"]:
        try:
            data = fetch_json(
                f"https://api.frankfurter.app/latest?from={currency}&to=JPY",
                headers={"User-Agent": "Mozilla/5.0"},
            )
            rate = round(data["rates"]["JPY"], 1)
            print(f"  {currency} → JPY: {rate}")
        except Exception as e:
            print(f"  {currency} → JPY: [Error: {e}]")


def step_expense():
    divider("💳 Expense Report")
    output = run("expense_report")
    if output:
        for line in output.splitlines():
            print(f"  {line}")
    else:
        print("  [No output]")


def step_calendar():
    divider("📅 Today's Calendar")
    gog_account = os.environ.get("GOG_ACCOUNT", "")
    events = []
    for cal_id, cal_name in CALENDARS:
        output = run(f'gog calendar events "{cal_id}" -a "{gog_account}" --today --plain')
        for line in output.splitlines():
            if not line.strip() or line.startswith("ID\t") or line == "No events":
                continue
            parts = line.split("\t")
            if len(parts) < 4:
                continue
            _, start, _, summary = parts[0], parts[1], parts[2], parts[3]
            if "T" in start:
                try:
                    time_str = datetime.fromisoformat(start).strftime("%H:%M")
                except Exception:
                    time_str = start
                events.append((time_str, summary, cal_name, False))
            else:
                events.append(("00:00", summary, cal_name, True))  # all-day sorts first

    events.sort(key=lambda x: x[0])
    if events:
        for time_str, summary, cal_name, all_day in events:
            if all_day:
                print(f"  • [All day] {summary}  ({cal_name})")
            else:
                print(f"  • {time_str} {summary}  ({cal_name})")
    else:
        print("  No events today.")


def step_real_estate():
    divider("🏠 Real Estate Metrics")
    output = run("daily_real_state")
    if output:
        for line in output.splitlines():
            print(f"  {line}")
    else:
        print("  [No output]")


# ── Main ───────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    today = datetime.now().strftime("%Y-%m-%d")
    print(f"🌅 Good Morning All — {today}")

    step_weather()
