                print(f"    小计: {card['subtotal']}")
        print(f"  💰 昨日总计: {data['total']}")
        print(f"  📊 本月至今 ({data['month']}): {data['accumulated_total']}")
    else:
        print(f"  上月 — {data['month']}")
        for card in data["cards"]:
            print(f"  {card_emoji(card['name'])} {card['name']}: {card['total']}")
        print(f"  💰 总计: {data['grand_total']}")


def step_calendar():
    divider("📅 今日安排")
    gog_account = os.environ.get("GOG_ACCOUNT", "")
    events = []
    for cal_id, cal_name in CALENDARS:
        output = run(f'gog calendar events "{cal_id}" -a "{gog_account}" --today --plain')
        for line in output.splitlines():
            if not line.strip() or line.startswith("ID\t") or line == "No events":
                continue
            parts = line.split("\t")
            if len(parts) < 4:
                continue
            _, start, _, summary = parts[0], parts[1], parts[2], parts[3]
            if "T" in start:
                try:
                    time_str = datetime.fromisoformat(start).strftime("%H:%M")
                except Exception:
                    time_str = start
                events.append((time_str, summary, cal_name, False))
            else:
                events.append(("00:00", summary, cal_name, True))  # all-day sorts first

    events.sort(key=lambda x: x[0])
    if events:
        for time_str, summary, cal_name, all_day in events:
            if all_day:
                print(f"  • [全天] {summary}  ({cal_name})")
            else:
                print(f"  • [{time_str}] {summary}  ({cal_name})")
    else:
        print("  [今日无活动]")


def step_real_estate():
    divider("🏠 房产指标")
    try:
        rows = json.loads(run("daily_real_state"))
    except Exception as e:
        print(f"  [Error: {e}]")
        return

    if not rows:
        print("  [数据未就绪]")
        return

    formatted = [
        (r["label"], f"¥{r['avg']}", str(r["count"]),
         fmt_pct(r["dod"]), fmt_pct(r["wow"]), fmt_pct(r["mom"]), fmt_pct(r["yoy"]))
        for r in rows
    ]
    headers = ("位置", "单价", "数量", "日变化", "周变化", "月变化", "年变化")

    # Compute column widths based on display width
    col_w = [dw(h) for h in headers]
    for row in formatted:
        for i, cell in enumerate(row):
            col_w[i] = max(col_w[i], dw(str(cell)))

    def render_row(cells):
        parts = []
        for i, cell in enumerate(cells):
            # right-align numeric/pct columns (all except Location)
            parts.append(lpad(str(cell), col_w[i]) if i > 0 else rpad(str(cell), col_w[i]))
        return "  " + " | ".join(parts)

    sep = "  " + "-" * (sum(col_w) + 3 * (len(col_w) - 1))
    print(render_row(headers))
    print(sep)
    for row in formatted:
        print(render_row(row))


