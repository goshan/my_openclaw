#!/bin/bash

# mail_fetch: fetch new messages in my Gmail account with a provided mail sender list, also manaage a database to save processed mails for deduplication
# Usage: mail_fetch <sender1> <sender2> ...
# These <sender>s don't need to be a full mail address, it can be part of address, ex. a postfix from `@` like `@gmail.com`, etc
# Notes: max fetching number is: 20
# Database is `mails_monitor` on the configured MySQL server

set -e

TMP_DIR=$(mktemp -d)
TMP_OUTPUT=$(mktemp)
TMP_LOG="${TMP_DIR}.log"

# fetch last execution time
new_time=$(date +"%Y-%m-%d %H:%M:%S")


# loop for each sender
new_count=0
for sender in  "$@"; do
  last_time=$(mysql_exec mails_monitor "SELECT last_scan_time FROM scan_state WHERE sender = %s LIMIT 1" "$sender")
  if [[ -z "$last_time" ]]; then
    # default fech from 5 days ago
    last_time=$(date -d "-5 days" +"%Y/%m/%d %H:%M:%S")
  fi
  last_day=$(date -d "$last_time 1 days ago" +"%Y/%m/%d")
  echo "last_time: $last_time" >> $TMP_LOG
  echo "last_day: $last_day" >> $TMP_LOG

  # fech new emails
  while read -r item; do
    message_id=$(echo $item | jq -r '.id')
    # skip if already processed before
    processed=$(mysql_exec mails_monitor "SELECT COUNT(*) FROM processed_emails WHERE message_id = %s" "$message_id")
    if [ "$processed" -gt 0 ]; then
      continue
    fi

    # fetch mail details
    message_content=$(gog gmail get $message_id --json --account $GOG_ACCOUNT 2>>$TMP_LOG)
    message_subject=$(echo $message_content | jq -r '.headers.subject')
    message_sender=$(echo $message_content | jq -r '.headers.from')
    message_date=$(date -d "$(echo $message_content | jq -r '.headers.date')" +"%Y-%m-%d %H:%M:%S")

    # save email content to file
    echo $message_content > "$TMP_DIR/$message_id.json"
    echo "=== EMAIL: $message_id ===" >> $TMP_OUTPUT
    mail_extract "$TMP_DIR/$message_id.json" >> $TMP_OUTPUT 2>>$TMP_LOG
    echo "" >> $TMP_OUTPUT

    # insert to processed_emails table
    mysql_exec mails_monitor "INSERT IGNORE INTO processed_emails (message_id, subject, sender, received_at) VALUES (%s, %s, %s, %s)" "$message_id" "$message_subject" "$message_sender" "$message_date"

    # update counter
    new_count=$((new_count + 1))
  done < <(gog gmail messages search "from:$sender after:$last_day" --max 20 --json --account $GOG_ACCOUNT 2>>$TMP_LOG | tee -a $TMP_LOG | jq -c '.messages[]' 2>>$TMP_LOG)

  # update last_scan_time (upsert)
  mysql_exec mails_monitor "REPLACE INTO scan_state (sender, last_scan_time) VALUES (%s, %s)" "$sender" "$new_time"
done

# Output result
echo "=== MAIL FETCH RESULT ==="

if [ "$new_count" -eq 0 ]; then
  echo "NO_NEW_EMAILS"
else
  echo "New emails found: $new_count"
  echo "Save all emails content to file: $TMP_OUTPUT"
fi

